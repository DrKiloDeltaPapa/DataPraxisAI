# DataPraxisAI RAG Backend Configuration

# ============================================================
# RAG Mode & Backend Selection
# ============================================================

# RAG_MODE determines which retrieval backend is used:
#   - seagate: Direct access to FAISS index + SQLite on Borg1 Seagate drive
#   - local: In-memory embeddings.json + cosine similarity (development fallback)
#   - agent: External HTTP agent (future; not yet implemented)
RAG_MODE=local

# ============================================================
# Lakehouse Storage (Borg1 Seagate drive)
# ============================================================

# Root directory where the AI lakehouse is stored
# On Borg1: /mnt/seagate_ai_corpus (external Seagate drive)
# On MacBook: will likely not exist; RAG_MODE should be 'local' or 'agent'
LAKEHOUSE_ROOT=/mnt/seagate_ai_corpus

# ============================================================
# FAISS Index Configuration
# ============================================================

# Path to FAISS vector index file (.faiss binary)
# Expected: $LAKEHOUSE_ROOT/indexes/llama3_bge_v1.faiss
FAISS_INDEX_PATH=$LAKEHOUSE_ROOT/indexes/llama3_bge_v1.faiss

# Path to FAISS ID mapping file (JSON)
# Maps internal FAISS row IDs to semantic chunk IDs
FAISS_IDMAP_PATH=$LAKEHOUSE_ROOT/indexes/llama3_bge_v1_idmap.json

# ============================================================
# Metadata & Chunk Database
# ============================================================

# Path to SQLite database containing:
#   - Chunk metadata (source file, doc_id, title, author, etc.)
#   - Full chunk text keyed by chunk_id
#   - Used to enrich RAG results with citations
METADATA_DB_PATH=$LAKEHOUSE_ROOT/metadata.db

# ============================================================
# Embedding Parameters
# ============================================================

# Embedding dimension (must match FAISS index dimension)
# Current index: 768
# If mismatch: server will reject and return 500 error
EMBEDDING_DIMENSION=768

# ============================================================
# RAG Retrieval Parameters
# ============================================================

# Default number of top-k chunks to retrieve
# Can be overridden per request; typical range: 4-16
TOP_K=8

# ============================================================
# External Agent Configuration (Future)
# ============================================================

# URL of external RAG agent service
# Used only when RAG_MODE=agent
# Format: http://host:port
RAG_AGENT_URL=http://127.0.0.1:9000

# ============================================================
# LLM Configuration (Blog Synthesis)
# ============================================================

# LLM_MODE determines which service generates blog content:
#   - ollama: Local LLM (free, recommended) — requires Ollama running
#   - openai: OpenAI API (paid) — requires OPENAI_API_KEY
#   - mock: Template-based fallback (no API needed, quality lower)
LLM_MODE=ollama

# Ollama endpoint (local LLM server)
# Default: http://127.0.0.1:11434
# To start Ollama:
#   1. Install: brew install ollama
#   2. Run: ollama run llama2
#   Then the server will be available at this URL
LLM_URL=http://127.0.0.1:11434

# Ollama model to use
# Popular models:
#   - llama2 (7B params, ~4GB memory)
#   - neural-chat (7B, optimized for chat)
#   - mistral (7B, fast and capable)
# List available: ollama list
LLM_MODEL=llama2

# OpenAI API Key (only needed if LLM_MODE=openai)
# Get from: https://platform.openai.com/api-keys
# Format: sk-...
OPENAI_API_KEY=

# ============================================================
# PLATFORM-SPECIFIC NOTES
# ============================================================

# Borg1 (Ubuntu workstation):
#   - RAG_MODE=seagate (use FAISS index)
#   - LLM_MODE=ollama or openai (your choice)
#   - Run Ollama locally or use OpenAI API
#
# MacBook (development):
#   - RAG_MODE=local (use embeddings.json)
#   - LLM_MODE=ollama (free) or mock (if Ollama not installed)
#   - Install Ollama: brew install ollama && ollama run llama2
